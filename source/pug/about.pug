section#about(class="main__section section section--lead")
  div(class="section__container section__container--lead container")
    h1(class="section__title title") Katherine Evtukhova
    p(class="section__tagline") Frontend developer
    div(class="section__picture-wrapper")
      picture
        source(type="image/webp", media="(min-width: 1200px)", srcset=`./images/lead-portrait-large@1x.webp 1x,
                  ./images/lead-portrait-large@2x.webp 2x`, width="508", height="501")
        source(type="image/webp", media="(min-width: 760px)", srcset=`./images/lead-portrait-medium@1x.webp 1x,
                  ./images/lead-portrait-medium@2x.webp 2x`, width="380", height="680")
        source(type="image/webp", srcset=`./images/lead-portrait-small@1x.webp 1x,
                  ./images/lead-portrait-small@2x.webp 2x`, width="760", height="380")
        source(type="image/jpg", media="(min-width: 1200px)", srcset=`./images/lead-portrait-large@1x.jpg 1x,
                    ./images/lead-portrait-large@2x.jpg 2x`, width="508", height="501")
        source(type="image/jpg", media="(min-width: 760px)", srcset=`./images/lead-portrait-medium@1x.jpg 1x,
                    ./images/lead-portrait-medium@2x.jpg 2x`, width="380", height="680")
        img(class="section__picture", src="./images/lead-portrait-small@1x.jpg", srcset="./images/lead-portrait-small@2x.jpg 2x", width="760", height="380", alt="Katherine Evtukhova")
    p(class="section__text") Built and released 5 browser games from scratch using TypeScript and Phaser. Strong experience in creating accessible and responsive layouts. Skilled in designing polished UI animations and motion effects. Sharp visual instincts backed by a professional background in 2D game art.
    ul(class="section__contacts-list")
      each contact in contacts
        li(class="section__contacts-item")
          a(class=`section__contacts-link button button--icon-${contact.name}`, href=contact.link)
            span(class="visually-hidden") contact.text
